<!DOCTYPE html>
<html>
  <head>
    <title>管理画面 | 通信プランシミュレーター</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="site-header admin-header">
      <div class="header-inner admin-header-inner">
        <span class="site-logo">管理画面</span>
        <nav class="admin-nav">
          <%# ブランド系（ブランドが親、プラン・割引が子） %>
          <%= link_to 'ブランド管理', admin_plan_brands_path, class: 'nav-link nav-parent' %>
          <%= link_to 'プラン管理', admin_plans_path, class: 'nav-link nav-child' %>
          <%= link_to '割引管理', admin_discounts_path, class: 'nav-link nav-child' %>
          <span class="nav-divider"></span>

          <%# 機種系（メーカーが親、機種が子） %>
          <%= link_to 'メーカー管理', admin_makers_path, class: 'nav-link nav-parent' %>
          <%= link_to '機種管理', admin_devices_path, class: 'nav-link nav-child' %>
          <span class="nav-divider"></span>

          <%# その他（独立したマスタ） %>
          <%= link_to 'サブスク管理', admin_subscriptions_path, class: 'nav-link nav-parent' %>
          <%= link_to 'オプション管理', admin_options_path, class: 'nav-link nav-parent' %>
          <%= link_to '手数料管理', admin_fees_path, class: 'nav-link nav-parent' %>
          <%= link_to 'ユーザー管理', admin_users_path, class: 'nav-link nav-parent' %>
          <span class="nav-divider"></span>

          <%# シミュレーターへ・ログアウト %>
          <%= link_to 'シミュレーターへ', root_path, class: 'nav-link nav-link-accent' %>
          <%= button_to 'ログアウト', logout_path, method: :delete, class: 'nav-btn' %>
        </nav>
      </div>
    </header>

    <main class="site-main">
      <% if notice %>
        <p class="flash flash-notice"><%= notice %></p>
      <% end %>
      <% if alert %>
        <p class="flash flash-alert"><%= alert %></p>
      <% end %>
      <%= yield %>
    </main>

    <%# 削除確認モーダル（普段は非表示） %>
    <div id="delete-modal" class="modal-overlay">
      <div class="modal">
        <h3 class="modal-title">削除の確認</h3>
        <p id="delete-modal-message" class="modal-message">本当に削除しますか？</p>
        <div class="modal-actions">
          <button type="button" id="delete-modal-cancel" class="modal-btn modal-btn-cancel">キャンセル</button>
          <button type="button" id="delete-modal-confirm" class="modal-btn modal-btn-danger">削除する</button>
        </div>
      </div>
    </div>
    
  </body>
</html>