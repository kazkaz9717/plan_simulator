<!DOCTYPE html>
<html>
  <head>
    <title>通信プランシミュレーター</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="<%= root_path %>" class="site-logo">通信プランシミュレーター</a>
        <nav class="site-nav">
          <% if logged_in? %>
            <span class="user-name"><%= current_user.name %>さん</span>
            <% if current_user.admin? %>
              <%= link_to '管理画面へ', admin_plans_path, class: 'nav-link nav-link-accent' %>
            <% end %>
            <%= button_to 'ログアウト', logout_path, method: :delete, class: 'nav-btn' %>
          <% else %>
            <% unless current_page?(login_path) %>
              <%= link_to 'ログイン', login_path, class: 'nav-link' %>
            <% end %>
          <% end %>
        </nav>
      </div>
    </header>

    <main class="site-main">
      <% if notice %>
        <p class="flash flash-notice"><%= notice %></p>
      <% end %>
      <% if alert %>
        <p class="flash flash-alert"><%= alert %></p>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>