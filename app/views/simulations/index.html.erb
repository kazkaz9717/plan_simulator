<h1>料金シミュレーター</h1>

<div class="tabs">
  <button class="tab-btn active" data-tab="plan">料金プラン</button>
  <button class="tab-btn" data-tab="discount">割引</button>
  <button class="tab-btn" data-tab="subscription">サブスクリプション</button>
  <button class="tab-btn" data-tab="option">オプション</button>
  <button class="tab-btn" data-tab="device">機種</button>
</div>

<%# 料金プランタブ %>
<div class="tab-content active" id="tab-plan">
  <h2>ブランドを選択</h2>
  <% @plan_brands.each do |brand| %>
    <label>
      <input type="radio" name="plan_brand" value="<%= brand.id %>">
      <%= brand.name %>
    </label>
  <% end %>

  <div id="plans-area">
    <p>ブランドを選択してください</p>
  </div>
</div>

<%# サブスクリプションタブ %>
<div class="tab-content" id="tab-subscription">
  <h2>サブスクリプションを選択</h2>
  <% @subscriptions.each do |subscription| %>
    <div class="plan-card">
      <label>
        <input type="checkbox" name="subscriptions[]" value="<%= subscription.id %>"
               data-price="<%= subscription.monthly_fee %>">
        <%= subscription.name %> ¥<%= number_with_delimiter(subscription.monthly_fee) %>/月
      </label>
    </div>
  <% end %>
</div>

<%# オプションタブ %>
<div class="tab-content" id="tab-option">
  <h2>オプションを選択</h2>
  <% @options.each do |option| %>
    <div class="plan-card">
      <label>
        <input type="checkbox" name="options[]" value="<%= option.id %>"
               data-price="<%= option.price %>">
        <%= option.name %> ¥<%= number_with_delimiter(option.price) %>
      </label>
      <div>
        分割回数：
        <select class="installment-select" data-price="<%= option.price %>">
          <option value="1">一括</option>
          <option value="12">12回</option>
          <option value="24">24回</option>
          <option value="36">36回</option>
          <option value="48">48回</option>
        </select>
      </div>
    </div>
  <% end %>
</div>

<%# 機種タブ %>
<div class="tab-content" id="tab-device">
  <h2>メーカーを選択</h2>
  <% @makers.each do |maker| %>
    <label>
      <input type="radio" name="device_maker" value="<%= maker.id %>">
      <%= maker.name %>
    </label>
  <% end %>

  <button type="button" id="clear-device">機種の選択をクリア</button>

  <div id="devices-area">
    <p>メーカーを選択してください</p>
  </div>
</div>

<%# 割引タブ %>
<div class="tab-content" id="tab-discount">
  <h2>割引を選択</h2>
  <div id="discounts-area">
    <p>先に料金プランタブでブランドを選択してください</p>
  </div>
</div>

<%# 結果エリア（内訳付き・横並び） %>
<div id="results-area"></div>

<script>
  const plansByBrand = <%= raw @plan_brands.map { |b|
    {
      id: b.id,
      plans: b.plans.map { |p|
        { id: p.id, name: p.name, monthly_fee: p.monthly_fee, category: p.category }
      }
    }
  }.to_json %>;

  const discounts = <%= raw @discounts.map { |d|
    {
      id: d.id,
      name: d.name,
      amount: d.amount,
      duration_months: d.duration_months,
      group_name: d.group_name,
      plan_brand_ids: d.plan_brand_ids
    }
  }.to_json %>;

  const devicesByMaker = <%= raw @makers.map { |m|
  {
    id: m.id,
    devices: m.devices.map { |d|
      { id: d.id, name: d.name, price: d.price, maker_name: m.name }
    }
  }
}.to_json %>;
</script>