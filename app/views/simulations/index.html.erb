<h1>料金シミュレーター</h1>

<div class="tabs">
  <button class="tab-btn active" data-tab="plan">料金プラン</button>
  <button class="tab-btn" data-tab="subscription">サブスクリプション</button>
  <button class="tab-btn" data-tab="option">オプション</button>
  <button class="tab-btn" data-tab="device">機種</button>
</div>

<%# 料金プランタブ %>
<div class="tab-content active" id="tab-plan">
  <h2>料金プランを選択</h2>
  <% @data_plans.each do |plan| %>
    <div class="plan-card">
      <label>
        <input type="radio" name="data_plan" value="<%= plan.id %>"
               data-price="<%= plan.monthly_fee %>">
        <%= plan.name %> ¥<%= number_with_delimiter(plan.monthly_fee) %>/月
      </label>
    </div>
  <% end %>

  <h3>音声通話プラン</h3>
  <div id="voice-plans">
    <p>先にデータプランを選択してください</p>
  </div>
</div>

<%# サブスクリプションタブ %>
<div class="tab-content" id="tab-subscription">
  <h2>サブスクリプションを選択</h2>
  <% @subscriptions.each do |subscription| %>
    <div class="plan-card">
      <label>
        <input type="checkbox" name="subscriptions[]" value="<%= subscription.id %>"
               data-price="<%= subscription.monthly_fee %>">
        <%= subscription.name %> ¥<%= number_with_delimiter(subscription.monthly_fee) %>/月
      </label>
    </div>
  <% end %>
</div>

<%# オプションタブ %>
<div class="tab-content" id="tab-option">
  <h2>オプションを選択</h2>
  <% @options.each do |option| %>
    <div class="plan-card">
      <label>
        <input type="checkbox" name="options[]" value="<%= option.id %>"
               data-price="<%= option.price %>">
        <%= option.name %> ¥<%= number_with_delimiter(option.price) %>
      </label>
      <div>
        分割回数：
        <select class="installment-select" data-price="<%= option.price %>">
          <option value="1">一括</option>
          <option value="12">12回</option>
          <option value="24">24回</option>
          <option value="36">36回</option>
          <option value="48">48回</option>
        </select>
      </div>
    </div>
  <% end %>
</div>

<%# 機種タブ %>
<div class="tab-content" id="tab-device">
  <h2>機種を選択</h2>
  <button type="button" id="clear-device">選択をクリア</button>
  <% @devices.each do |device| %>
    <div class="plan-card">
      <label>
        <input type="radio" name="device" value="<%= device.id %>"
               data-price="<%= device.price %>">
        <%= device.name %>
        （<%= device.maker.name %> / <%= device.device_grade.name %>）
        ¥<%= number_with_delimiter(device.price) %>
      </label>
      <div>
        分割回数：
        <select class="installment-select" data-price="<%= device.price %>">
          <option value="1">一括</option>
          <option value="12">12回</option>
          <option value="24">24回</option>
          <option value="36">36回</option>
          <option value="48">48回</option>
        </select>
      </div>
    </div>
  <% end %>
</div>

<%# 合計金額 %>
<div class="total">
  <h2>月額合計：¥<span id="total-fee">0</span></h2>
  <h2>当日払う料金：¥<span id="today-fee">0</span></h2>
</div>

<script>
  const planCombinations = <%= raw @plan_combinations.to_json %>;
  const voicePlans = <%= raw @voice_plans.to_json %>;
</script>