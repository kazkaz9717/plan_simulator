<h1>ユーザー管理</h1>
<%= link_to '新規追加', new_admin_user_path %>

<table>
  <thead>
    <tr>
      <th>ユーザー名</th>
      <th>権限</th>
      <th>操作</th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.name %></td>
        <td><%= user.role %></td>
        <td>
          <%= link_to '編集', edit_admin_user_path(user) %>
          <%= button_to '削除', admin_user_path(user), method: :delete,
              data: { turbo_confirm: '本当に削除しますか？' } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>