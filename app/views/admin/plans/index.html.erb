<h1>プラン管理</h1>
<%= link_to '新規追加', new_admin_plan_path %>

<table>
  <thead>
    <tr>
      <th>プラン名</th>
      <th>カテゴリ</th>
      <th>月額料金</th>
      <th>説明</th>
      <th>操作</th>
    </tr>
  </thead>
  <tbody>
    <% @plans.each do |plan| %>
      <tr>
        <td><%= plan.name %></td>
        <td><%= plan.plan_category.name %></td>
        <td>¥<%= number_with_delimiter(plan.monthly_fee) %></td>
        <td><%= plan.description %></td>
        <td>
          <%= link_to '編集', edit_admin_plan_path(plan) %>
          <%= button_to '削除', admin_plan_path(plan), method: :delete,
              data: { turbo_confirm: '本当に削除しますか？' } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>