<h1>プラン管理</h1>
<%= link_to '新規追加', new_admin_plan_path %>

<%# ブランドタブ %>
<div class="tabs">
  <%= link_to 'すべて', admin_plans_path,
      class: params[:plan_brand_id].blank? ? 'tab-btn active' : 'tab-btn' %>
  <% @plan_brands.each do |brand| %>
    <%= link_to brand.name, admin_plans_path(plan_brand_id: brand.id),
        class: params[:plan_brand_id] == brand.id.to_s ? 'tab-btn active' : 'tab-btn' %>
  <% end %>
</div>

<% grouped = @plans.group_by(&:group_name) %>
<% sorted_groups = grouped.sort_by { |group_name, _| group_name.nil? ? 1 : 0 } %>
<% sorted_groups.each do |group_name, plans_in_group| %>
  <h2>▼ <%= group_name.presence || 'グループなし' %></h2>
  <table>
    <thead>
      <tr>
        <th>プラン名</th>
        <th>ブランド</th>
        <th>月額料金</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% plans_in_group.each do |plan| %>
        <tr>
          <td data-label="プラン名"><%= plan.name %></td>
          <td data-label="ブランド"><%= plan.plan_brands.map(&:name).join(', ') %></td>
          <td data-label="月額料金">¥<%= number_with_delimiter(plan.monthly_fee) %></td>
          <td>
            <%= link_to '編集', edit_admin_plan_path(plan) %>
            <%= button_to '削除', admin_plan_path(plan), method: :delete,
                form_class: 'js-delete-form button_to' %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>