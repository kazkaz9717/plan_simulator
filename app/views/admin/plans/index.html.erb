<h1>プラン管理</h1>
<%= link_to '新規追加', new_admin_plan_path %>

<%# ブランドタブ %>
<div class="tabs">
  <%= link_to 'すべて', admin_plans_path,
      class: params[:plan_brand_id].blank? ? 'tab-btn active' : 'tab-btn' %>
  <% @plan_brands.each do |brand| %>
    <%= link_to brand.name, admin_plans_path(plan_brand_id: brand.id),
        class: params[:plan_brand_id] == brand.id.to_s ? 'tab-btn active' : 'tab-btn' %>
  <% end %>
</div>

<% Plan::CATEGORIES.each do |category| %>
  <% plans_in_category = @plans.select { |p| p.category == category } %>
  <% next if plans_in_category.empty? %>

  <h2>▼ <%= category %></h2>
  <table>
    <thead>
      <tr>
        <th>プラン名</th>
        <th>ブランド</th>
        <th>月額料金</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% plans_in_category.each do |plan| %>
        <tr>
          <td><%= plan.name %></td>
          <td><%= plan.plan_brands.map(&:name).join(', ') %></td>
          <td>¥<%= number_with_delimiter(plan.monthly_fee) %></td>
          <td>
            <%= link_to '編集', edit_admin_plan_path(plan) %>
            <%= button_to '削除', admin_plan_path(plan), method: :delete,
                data: { turbo_confirm: '本当に削除しますか？' } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>