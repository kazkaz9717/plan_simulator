<h1>オプション品管理</h1>
<%= link_to '新規追加', new_admin_option_path %>

<% grouped = @options.group_by(&:group_name) %>
<% sorted_groups = grouped.sort_by { |group_name, _| group_name.nil? ? 1 : 0 } %>
<% sorted_groups.each do |group_name, options_in_group| %>
  <h2>▼ <%= group_name.presence || 'グループなし' %></h2>
  <table>
    <thead>
      <tr>
        <th>オプション品名</th>
        <th>価格</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% options_in_group.each do |option| %>
        <tr>
          <td><%= option.name %></td>
          <td>¥<%= number_with_delimiter(option.price) %></td>
          <td>
            <%= link_to '編集', edit_admin_option_path(option) %>
            <%= button_to '削除', admin_option_path(option), method: :delete,
                data: { turbo_confirm: '本当に削除しますか？' } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>