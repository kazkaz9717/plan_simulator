<h1>割引管理</h1>
<%= link_to '新規追加', new_admin_discount_path %>

<%# ブランドタブ %>
<div class="tabs">
  <%= link_to 'すべて', admin_discounts_path,
      class: params[:plan_brand_id].blank? ? 'tab-btn active' : 'tab-btn' %>
  <% @plan_brands.each do |brand| %>
    <%= link_to brand.name, admin_discounts_path(plan_brand_id: brand.id),
        class: params[:plan_brand_id] == brand.id.to_s ? 'tab-btn active' : 'tab-btn' %>
  <% end %>
</div>

<% grouped = @discounts.group_by(&:group_name) %>
<% sorted_groups = grouped.sort_by { |group_name, _| group_name.nil? ? 1 : 0 } %>
<% sorted_groups.each do |group_name, discounts_in_group| %>
  <h2>▼ <%= group_name.presence || 'グループなし' %></h2>
  <table>
    <thead>
      <tr>
        <th>割引名</th>
        <th>対象ブランド</th>
        <th>割引額/月</th>
        <th>適用期間</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% discounts_in_group.each do |discount| %>
        <tr>
          <td><%= discount.name %></td>
          <td><%= discount.plan_brands.map(&:name).join(', ') %></td>
          <td>¥<%= number_with_delimiter(discount.amount) %></td>
          <td><%= discount.duration_months ? "#{discount.duration_months}ヶ月間" : '永年' %></td>
          <td>
            <%= link_to '編集', edit_admin_discount_path(discount) %>
            <%= button_to '削除', admin_discount_path(discount), method: :delete,
                data: { turbo_confirm: '本当に削除しますか？' } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>