<%= form_with model: [:admin, device] do |f| %>
  <% if device.errors.any? %>
    <ul>
      <% device.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  <% end %>

  <div>
    <%= f.label :name, '機種名' %>
    <%= f.text_field :name %>
  </div>

  <div>
    <%= f.label :maker_id, 'メーカー' %>
    <%= f.collection_select :maker_id, @makers, :id, :name, prompt: '選択してください' %>
  </div>

  <div>
    <%= f.label :device_grade_id, 'グレード' %>
    <%= f.collection_select :device_grade_id, @device_grades, :id, :name, prompt: '選択してください' %>
  </div>

  <div>
    <%= f.label :price, '価格' %>
    <%= f.number_field :price %>
  </div>

  <div>
    <%= f.label :description, '説明' %>
    <%= f.text_area :description %>
  </div>

  <%= f.submit %>
<% end %>