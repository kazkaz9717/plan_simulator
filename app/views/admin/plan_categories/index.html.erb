<h1>プランカテゴリ管理</h1>
<%= link_to '新規追加', new_admin_plan_category_path %>

<table>
  <thead>
    <tr>
      <th>カテゴリ名</th>
      <th>操作</th>
    </tr>
  </thead>
  <tbody>
    <% @plan_categories.each do |plan_category| %>
      <tr>
        <td><%= plan_category.name %></td>
        <td>
          <%= link_to '編集', edit_admin_plan_category_path(plan_category) %>
          <%= button_to '削除', admin_plan_category_path(plan_category), method: :delete,
              data: { turbo_confirm: '本当に削除しますか？' } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>