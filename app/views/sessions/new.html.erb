<h1>ログイン</h1>

<%= form_with url: login_path do |f| %>
  <div>
    <%= f.label :name, 'ユーザー名' %>
    <%= f.text_field :name %>
  </div>

  <div>
    <%= f.label :password, 'パスワード' %>
    <%= f.password_field :password %>
  </div>

  <div>
    <%= f.submit 'ログイン' %>
  </div>
<% end %>

<div>
  <%= button_to 'ゲストログイン', guest_login_path, method: :post %>
</div>